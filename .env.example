# New, dedicated Supabase project for Backyard Pickle
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Accounts: replace every example value before running create-accounts.js
OWNER_EMAIL=owner@your-platform-domain.com
OWNER_PASSWORD=CHANGE_THIS_TO_A_LONG_UNIQUE_PASSWORD
COURT_OWNER_EMAIL=owner@backyardpickle.example
COURT_OWNER_PASSWORD=CHANGE_THIS_TO_A_LONG_UNIQUE_PASSWORD
STAFF_EMAIL=staff@backyardpickle.example
STAFF_PASSWORD=CHANGE_THIS_TO_A_LONG_UNIQUE_PASSWORD

# Cloudflare Pages
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=backyard-pickle-pickleball
CLOUDFLARE_PAGES_BRANCH=main

# Edge Function branding/secrets (configure with Supabase secrets)
GOOGLE_VISION_API_KEY=YOUR_RESTRICTED_GOOGLE_VISION_API_KEY
MAILEROO_API_KEY=YOUR_MAILEROO_SENDING_KEY
APP_BASE_URL=https://backyard-pickle.example
APP_ADMIN_URL=https://backyard-pickle.example/admin.html
BRAND_NAME=Backyard Pickle
VENUE_LOCATION=Location to be announced
BRAND_LOGO_URL=https://backyard-pickle.example/backyardpicklelogo.jpg
SUPPORT_PHONE=0915 393 4597
FACEBOOK_URL=https://web.facebook.com/profile.php?id=61590034812771
EMAIL_FROM=Backyard Pickle <bookings@backyard-pickle.example>
